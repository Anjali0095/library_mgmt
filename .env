# ─────────────────────────────────────────────────────────────────────────────
#  Bibliotheca — Docker environment variables
#  Copy this to .env and fill in your values before running docker-compose up
# ─────────────────────────────────────────────────────────────────────────────

# MySQL running on your LOCAL machine
# On Mac/Windows: host.docker.internal works out of the box
# On Linux:       use your machine's LAN IP, e.g. 192.168.1.10
DB_HOST=172.18.75.153
DB_PORT=3306
DB_USER=root
DB_PASSWORD=qwerty123
DB_NAME=library_mgmt

# JWT — change this to a long random string in production!
JWT_SECRET=25d3ebbe458f64473c2828c906fb79ca8799b6ce4adb6f6c6b04538378994c66
JWT_EXPIRES_IN=7d

# The URL the BROWSER uses to reach the backend API
# Keep as localhost:5000 when running on your local machine
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# The URL the backend uses for CORS allow-list
FRONTEND_URL=http://localhost:3000
